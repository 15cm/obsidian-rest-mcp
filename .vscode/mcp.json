{
	"servers": {
		"obsidianLocalRest": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-i",
				"-e",
				"OBSIDIAN_API_KEY=${input:obsidian-api-key}",
				"-e",
				"OBSIDIAN_REST_URL=https://host.docker.internal:27124",
				"-e",
				"OBSIDIAN_OPENAPI_PATH=/openapi.yaml",
				"ghcr.io/alexw00/obsidian-rest-mcp:latest"
			]
		}
	},
	"inputs": [
		{
			"type": "promptString",
			"id": "obsidian-api-key",
			"description": "Obsidian Local REST API key (Bearer token)",
			"password": true
		}
	]
}
